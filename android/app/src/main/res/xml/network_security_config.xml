<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP only for local development servers -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Android Emulator loopback alias for development host -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Local network development server IP -->
        <domain includeSubdomains="true">192.168.1.5</domain>
    </domain-config>
    
    <!-- Enforce HTTPS/SSL/TLS globally for production -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
